# Staging Environment Configuration
# 测试环境配置

VITE_API_URL=https://staging-api.pawsync.com
VITE_ENV=staging
VITE_ENABLE_MOCK_DATA=false

# Backend Server
VITE_BACKEND_URL=https://staging-api.pawsync.com
VITE_WS_URL=wss://staging-api.pawsync.com

# Debug Features
VITE_ENABLE_DEBUG_LOG=true
VITE_ENABLE_PERFORMANCE_LOG=true
