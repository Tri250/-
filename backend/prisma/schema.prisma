generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  pets      Pet[]
  bookmarks ManualBookmark[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pet {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  avatar         String?
  type           PetType
  breed          String?
  gender         PetGender
  birthday       DateTime?
  weight         Float?
  color          String?
  characteristics String?
  healthStatus   HealthStatus     @default(GOOD)
  healthRecords  HealthRecord[]
  vaccines       PetVaccine[]
  checkups       PetCheckup[]
  growthRecords  PetGrowth[]
  reminders      Reminder[]
  conversations  AIConversation[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model HealthRecord {
  id             String        @id @default(uuid())
  petId          String
  pet            Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  type           RecordType
  title          String
  content        String
  tags           String[]
  attachments    String[]
  voiceDuration  Int?
  isImportant    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PetVaccine {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime
  nextDate  DateTime?
  vet       String?
  notes     String?
  createdAt DateTime @default(now())
}

model PetCheckup {
  id          String   @id @default(uuid())
  petId       String
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date        DateTime
  weight      Float?
  vet         String?
  notes       String?
  attachments String[]
  createdAt   DateTime @default(now())
}

model PetGrowth {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date      DateTime
  weight    Float?
  height    Float?
  notes     String?
  createdAt DateTime @default(now())
}

model Reminder {
  id          String       @id @default(uuid())
  petId       String
  pet         Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  type        ReminderType
  title       String
  notes       String?
  date        DateTime
  time        String
  repeat      RepeatType
  endDate     DateTime?
  isCompleted Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
}

model AIConversation {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  userId    String
  messages  Message[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, petId])
  @@index([createdAt])
}

model Message {
  id        String    @id @default(uuid())
  conversationId String
  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role      String // "user" or "assistant"
  content   String
  timestamp DateTime @default(now())
}

model HealthReport {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, petId])
}

model HealthManual {
  id          String           @id @default(uuid())
  title       String
  content     String
  category    ManualCategory
  petType     PetType?
  tags        String[]
  author      String?
  viewCount   Int              @default(0)
  isOfficial  Boolean          @default(true)
  bookmarks   ManualBookmark[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ManualBookmark {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  manualId  String
  manual    HealthManual  @relation(fields: [manualId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

enum PetType {
  DOG
  CAT
  OTHER
}

enum PetGender {
  MALE
  FEMALE
}

enum HealthStatus {
  EXCELLENT
  GOOD
  FAIR
  CONCERN
}

enum RecordType {
  TEXT
  VOICE
  PHOTO
  VIDEO
  FILE
}

enum ReminderType {
  VACCINE
  DEWORMING
  CHECKUP
  BATH
  BRUSH_TEETH
  MEDICINE
  GROOMING
  CUSTOM
}

enum RepeatType {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum ManualCategory {
  NUTRITION
  CARE
  BEHAVIOR
  EMERGENCY
  TRAINING
}
