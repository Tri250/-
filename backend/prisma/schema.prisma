generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  pets      Pet[]
  healthRecords HealthRecord[]
  healthReports HealthReport[]
  bookmarks ManualBookmark[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pet {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  avatar         String?
  type           String           // "DOG", "CAT", "OTHER"
  breed          String?
  gender         String           // "MALE", "FEMALE"
  birthday       DateTime?
  weight         Float?
  color          String?
  characteristics String?
  healthStatus   String           @default("GOOD") // "EXCELLENT", "GOOD", "FAIR", "CONCERN"
  healthRecords  HealthRecord[]
  vaccines       PetVaccine[]
  checkups       PetCheckup[]
  growthRecords  PetGrowth[]
  reminders      Reminder[]
  conversations  AIConversation[]
  healthReports  HealthReport[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model HealthRecord {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  petId          String
  pet            Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  type           String        // "TEXT", "VOICE", "PHOTO", "VIDEO", "FILE"
  title          String
  content        String
  tags           String        // JSON array
  attachments    String        // JSON array
  voiceDuration  Int?
  isImportant    Boolean       @default(false)
  recordDate     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([userId, recordDate])
  @@index([userId, petId])
}

model PetVaccine {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime
  nextDate  DateTime?
  vet       String?
  notes     String?
  createdAt DateTime @default(now())
}

model PetCheckup {
  id          String   @id @default(uuid())
  petId       String
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date        DateTime
  weight      Float?
  vet         String?
  notes       String?
  attachments String   // JSON array
  createdAt   DateTime @default(now())
}

model PetGrowth {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date      DateTime
  weight    Float?
  height    Float?
  notes     String?
  createdAt DateTime @default(now())
}

model Reminder {
  id          String       @id @default(uuid())
  petId       String
  pet         Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  type        String       // "VACCINE", "DEWORMING", "CHECKUP", "BATH", "BRUSH_TEETH", "MEDICINE", "GROOMING", "CUSTOM"
  title       String
  notes       String?
  date        DateTime
  time        String
  repeat      String       // "ONCE", "DAILY", "WEEKLY", "MONTHLY", "YEARLY"
  endDate     DateTime?
  isCompleted Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
}

model AIConversation {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  userId    String
  messages  Message[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, petId])
  @@index([createdAt])
}

model Message {
  id             String    @id @default(uuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" or "assistant"
  content        String
  timestamp      DateTime @default(now())
}

model HealthReport {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, petId])
}

model HealthManual {
  id          String           @id @default(uuid())
  title       String
  content     String
  category    String           // "NUTRITION", "CARE", "BEHAVIOR", "EMERGENCY", "TRAINING"
  petType     String?
  tags        String           // JSON array
  author      String?
  viewCount   Int              @default(0)
  isOfficial  Boolean          @default(true)
  bookmarks   ManualBookmark[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ManualBookmark {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  manualId  String
  manual    HealthManual  @relation(fields: [manualId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}
