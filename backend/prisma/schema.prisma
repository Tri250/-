generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(uuid())
  email     String        @unique
  password  String
  name      String
  avatar    String?
  pets      Pet[]
  bookmarks ManualBookmark[]
  devices   SmartDevice[]  // 智能设备
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pet {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  avatar         String?
  type           String           // PetType: DOG, CAT, OTHER
  breed          String?
  gender         String           // PetGender: MALE, FEMALE
  birthday       DateTime?
  weight         Float?
  color          String?
  characteristics String?
  healthStatus   String           @default("GOOD") // HealthStatus: EXCELLENT, GOOD, FAIR, CONCERN
  healthRecords  HealthRecord[]
  vaccines       PetVaccine[]
  checkups       PetCheckup[]
  growthRecords  PetGrowth[]
  reminders      Reminder[]
  conversations  AIConversation[]
  memories       Memory[]         // 宠物回忆
  voiceRecords   VoiceRecord[]    // 声音记录
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model HealthRecord {
  id             String        @id @default(uuid())
  petId          String
  pet            Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  type           String        // RecordType: TEXT, VOICE, PHOTO, VIDEO, FILE
  title          String
  content        String
  tags           String        // JSON 数组字符串
  attachments    String        // JSON 数组字符串
  voiceDuration  Int?
  isImportant    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PetVaccine {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime
  nextDate  DateTime?
  vet       String?
  notes     String?
  createdAt DateTime @default(now())
}

model PetCheckup {
  id          String   @id @default(uuid())
  petId       String
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date        DateTime
  weight      Float?
  vet         String?
  notes       String?
  attachments String   // JSON 数组字符串
  createdAt   DateTime @default(now())
}

model PetGrowth {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date      DateTime
  weight    Float?
  height    Float?
  notes     String?
  createdAt DateTime @default(now())
}

model Reminder {
  id          String       @id @default(uuid())
  petId       String
  pet         Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  type        String       // ReminderType: VACCINE, DEWORMING, CHECKUP, BATH, BRUSH_TEETH, MEDICINE, GROOMING, CUSTOM
  title       String
  notes       String?
  date        DateTime
  time        String
  repeat      String       // RepeatType: ONCE, DAILY, WEEKLY, MONTHLY, YEARLY
  endDate     DateTime?
  isCompleted Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
}

model AIConversation {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  userId    String
  messages  String   // JSON 数组字符串
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HealthManual {
  id          String           @id @default(uuid())
  title       String
  content     String
  category    String           // ManualCategory: NUTRITION, CARE, BEHAVIOR, EMERGENCY, TRAINING
  petType     String?          // PetType: DOG, CAT, OTHER
  tags        String           // JSON 数组字符串
  author      String?
  viewCount   Int              @default(0)
  isOfficial  Boolean          @default(true)
  bookmarks   ManualBookmark[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ManualBookmark {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  manualId  String
  manual    HealthManual  @relation(fields: [manualId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

// ==================== 回忆模块 ====================

/// 宠物回忆/相册模型
model Memory {
  id          String       @id @default(uuid())
  petId       String
  pet         Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        String       @default("PHOTO") // MemoryType: PHOTO, VIDEO
  mediaUrl    String       // 媒体文件URL（图片/视频）
  thumbnailUrl String?     // 缩略图URL
  location    String?      // 拍摄地点
  tags        String       // JSON 数组字符串
  isFavorite  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([petId])
  @@index([createdAt])
}

// ==================== 声音记录模块 ====================

/// 声音记录模型
model VoiceRecord {
  id              String         @id @default(uuid())
  petId           String
  pet             Pet            @relation(fields: [petId], references: [id], onDelete: Cascade)
  audioUrl        String         // 音频文件URL
  duration        Int            // 时长（秒）
  emotion         String?        // EmotionType: HAPPY, SAD, ANGRY, FEARFUL, ANXIOUS, EXCITED, CALM, CONFUSED, PLAYFUL, AFFECTIONATE
  confidence      Float?         // 分析置信度
  translation     String?        // 翻译结果
  suggestion      String?        // 建议
  analysisDetails String?        // JSON 字符串
  isAnalyzed      Boolean        @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([petId])
  @@index([createdAt])
}

// ==================== 智能设备模块 ====================

/// 智能设备模型
model SmartDevice {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String         // 设备名称
  deviceType    String         // DeviceType: FEEDER, WATER_DISPENSER, CAMERA, TOY, TRACKER, LITTER_BOX, DOOR, OTHER
  deviceId      String         @unique // 设备唯一标识
  status        String         @default("OFFLINE") // DeviceStatus: ONLINE, OFFLINE, MAINTENANCE, ERROR
  lastOnline    DateTime?      // 最后在线时间
  config        String?        // JSON 字符串
  batteryLevel  Int?           // 电池电量
  firmwareVersion String?      // 固件版本
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  commands      DeviceCommand[] // 设备指令记录
  
  @@index([userId])
  @@index([deviceType])
}

/// 设备指令模型
model DeviceCommand {
  id          String         @id @default(uuid())
  deviceId    String
  device      SmartDevice    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  command     String         // 指令类型
  params      String?        // JSON 字符串
  status      String         @default("PENDING") // CommandStatus: PENDING, EXECUTING, SUCCESS, FAILED, TIMEOUT
  result      String?        // JSON 字符串
  executedAt  DateTime?      // 执行时间
  createdAt   DateTime       @default(now())
  
  @@index([deviceId])
  @@index([status])
}