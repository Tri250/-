<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.pawsync.pro">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- 主Activity -->
        <activity android:name=".ui.activity.MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- 主要页面 -->
        <activity android:name=".ui.activity.DevicesActivity" android:exported="false"/>
        <activity android:name=".ui.activity.RecordsActivity" android:exported="false"/>
        <activity android:name=".ui.activity.ProfileActivity" android:exported="false"/>

        <!-- 功能页面 -->
        <activity android:name=".ui.activity.AIConsultantActivity" android:exported="false"/>
        <activity android:name=".ui.activity.HealthActivity" android:exported="false"/>
        <activity android:name=".ui.activity.DietAdviceActivity" android:exported="false"/>
        <activity android:name=".ui.activity.PetsActivity" android:exported="false"/>
        <activity android:name=".ui.activity.TrainingActivity" android:exported="false"/>
        <activity android:name=".ui.activity.InsuranceActivity" android:exported="false"/>
        <activity android:name=".ui.activity.MedicalActivity" android:exported="false"/>
        <activity android:name=".ui.activity.ServicesActivity" android:exported="false"/>

        <!-- 设备相关 -->
        <activity android:name=".ui.activity.AddDeviceActivity" android:exported="false"/>
        <activity android:name=".ui.activity.DeviceDetailActivity" android:exported="false"/>
        <activity android:name=".ui.activity.DeviceManageActivity" android:exported="false"/>

        <!-- 记录相关 -->
        <activity android:name=".ui.activity.RecordDetailActivity" android:exported="false"/>

        <!-- 我的页面相关 -->
        <activity android:name=".ui.activity.AppointmentsActivity" android:exported="false"/>
        <activity android:name=".ui.activity.FavoritesActivity" android:exported="false"/>
        <activity android:name=".ui.activity.CouponsActivity" android:exported="false"/>
        <activity android:name=".ui.activity.FamilyActivity" android:exported="false"/>
        <activity android:name=".ui.activity.SettingsActivity" android:exported="false"/>
        <activity android:name=".ui.activity.HelpFeedbackActivity" android:exported="false"/>
        <activity android:name=".ui.activity.AboutActivity" android:exported="false"/>

    </application>

</manifest>