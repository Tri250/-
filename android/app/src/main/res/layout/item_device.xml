<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp"
    android:background="@color/bg_card" android:layout_marginBottom="12dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">

        <!-- 设备图标 -->
        <ImageView android:id="@+id/device_icon" android:layout_width="64dp" android:layout_height="64dp"
            android:padding="16dp" android:background="@drawable/bg_action_orange"
            android:src="@drawable/ic_feeder"/>

        <!-- 设备信息 -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="12dp"
            android:orientation="vertical">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/device_name" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="16sp"
                    android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
                    android:text="毛球的碗"/>
                <ImageView android:layout_width="14dp" android:layout_height="14dp"
                    android:layout_marginStart="4dp" android:src="@drawable/ic_edit"
                    android:tint="@color/text_tertiary"/>
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:orientation="horizontal">
                <View android:layout_width="6dp" android:layout_height="6dp"
                    android:background="@color/status_online"/>
                <TextView android:id="@+id/device_status" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginStart="4dp"
                    android:textSize="11sp" android:textColor="@color/status_online"
                    android:text="在线"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" android:textSize="11sp"
                    android:textColor="@color/text_tertiary" android:text="|"/>
                <TextView android:id="@+id/device_battery" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginStart="8dp"
                    android:textSize="11sp" android:textColor="@color/text_secondary"
                    android:text="剩余电量 85%"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 管理按钮 -->
        <TextView android:id="@+id/device_manage" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:paddingHorizontal="10dp"
            android:paddingVertical="6dp" android:textSize="12sp"
            android:textColor="@color/brand_primary" android:background="@drawable/bg_action_orange"
            android:text="设备管理"/>
    </LinearLayout>

    <!-- 今日数据 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:orientation="horizontal"
        android:gravity="center" android:paddingTop="12dp"
        android:background="@color/bg_primary">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="@color/text_tertiary"
                android:text="今日喂食"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:textSize="13sp"
                android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
                android:text="2次"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="@color/text_tertiary"
                android:text="今日进食"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:textSize="13sp"
                android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
                android:text="320g"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="@color/text_tertiary"
                android:text="设备状态"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:textSize="13sp"
                android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
                android:text="正常"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>