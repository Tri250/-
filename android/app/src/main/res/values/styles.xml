<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
    PawSync Pro 4.0 温暖治愈版
    styles.xml - Material Design 3 主题配置
    
    优化要点：
    1. Material Design 3 (Material You) 主题
    2. 动态颜色支持（Android 12+）
    3. 深色模式适配
    4. 无边框启动屏幕
    5. 触摸反馈优化
    -->

    <!-- ============================================
         Material Design 3 基础主题
         ============================================ -->

    <!-- 主主题 - Material Design 3 -->
    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <!-- 主色 - 暖橙（关爱、温暖） -->
        <item name="colorPrimary">@color/primary_500</item>
        <item name="colorPrimaryDark">@color/primary_600</item>
        <item name="colorPrimaryVariant">@color/primary_400</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- 辅色 - 薄荷绿（健康、专业） -->
        <item name="colorSecondary">@color/secondary_500</item>
        <item name="colorSecondaryVariant">@color/secondary_400</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- 强调色 -->
        <item name="colorAccent">@color/primary_500</item>

        <!-- 背景色 -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnBackground">@color/on_background_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>

        <!-- 状态栏颜色 -->
        <item name="android:statusBarColor">@color/status_bar_light</item>
        <item name="android:navigationBarColor">@color/nav_bar_light</item>

        <!-- 触摸反馈 -->
        <item name="android:selectableItemBackground">@drawable/ripple_primary</item>
        <item name="android:selectableItemBackgroundBorderless">@drawable/ripple_primary_borderless</item>

        <!-- 字体 -->
        <item name="android:fontFamily">@font/google_sans</item>

        <!-- 动画 -->
        <item name="android:windowAnimationStyle">@style/WindowAnimation</item>

        <!-- Material Design 3 特性 -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Large</item>
    </style>

    <!-- 深色模式主题 -->
    <style name="AppTheme.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <!-- 主色 - 暖橙 -->
        <item name="colorPrimary">@color/primary_500</item>
        <item name="colorPrimaryDark">@color/primary_700</item>
        <item name="colorPrimaryVariant">@color/primary_400</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- 辅色 - 薄荷绿 -->
        <item name="colorSecondary">@color/secondary_500</item>
        <item name="colorSecondaryVariant">@color/secondary_400</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- 强调色 -->
        <item name="colorAccent">@color/primary_500</item>

        <!-- 背景色 -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnBackground">@color/on_background_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>

        <!-- 状态栏颜色 -->
        <item name="android:statusBarColor">@color/status_bar_dark</item>
        <item name="android:navigationBarColor">@color/nav_bar_dark</item>

        <!-- 触摸反馈 -->
        <item name="android:selectableItemBackground">@drawable/ripple_primary_dark</item>
        <item name="android:selectableItemBackgroundBorderless">@drawable/ripple_primary_borderless_dark</item>

        <!-- 字体 -->
        <item name="android:fontFamily">@font/google_sans</item>

        <!-- 动画 -->
        <item name="android:windowAnimationStyle">@style/WindowAnimation</item>

        <!-- Material Design 3 特性 -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Large</item>
    </style>

    <!-- ============================================
         无ActionBar主题（主Activity使用）
         ============================================ -->

    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowBackground">@color/background_light</item>
    </style>

    <style name="AppTheme.NoActionBar.Dark" parent="AppTheme.Dark">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <!-- ============================================
         启动屏幕主题
         ============================================ -->

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- 启动屏幕背景 -->
        <item name="android:background">@drawable/splash</item>
        <item name="android:windowBackground">@drawable/splash</item>

        <!-- 启动屏幕动画 -->
        <item name="android:windowAnimationStyle">@style/SplashAnimation</item>

        <!-- 状态栏颜色 -->
        <item name="android:statusBarColor">@color/primary_500</item>
        <item name="android:navigationBarColor">@color/primary_500</item>

        <!-- 隐藏ActionBar -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- ============================================
         窗口动画
         ============================================ -->

    <style name="WindowAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="SplashAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
    </style>

    <!-- ============================================
         Material Design 3 形状外观
         ============================================ -->

    <style name="ShapeAppearance.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- ============================================
         Material Design 3 组件样式
         ============================================ -->

    <!-- 按钮样式 -->
    <style name="Widget.App.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary_500</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:fontFamily">@font/google_sans_medium</item>
    </style>

    <style name="Widget.App.Button.Secondary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/secondary_500</item>
        <item name="android:textColor">@color/on_secondary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:fontFamily">@font/google_sans_medium</item>
    </style>

    <!-- 卡片样式 -->
    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_light</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="rippleColor">@color/primary_100</item>
    </style>

    <!-- Chip样式 -->
    <style name="Widget.App.Chip" parent="Widget.Material3.Chip.Input">
        <item name="chipBackgroundColor">@color/primary_100</item>
        <item name="chipStrokeColor">@color/primary_200</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">8dp</item>
        <item name="android:textColor">@color/primary_600</item>
    </style>

    <!-- FAB样式 -->
    <style name="Widget.App.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary_500</item>
        <item name="tint">@color/on_primary</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Medium</item>
        <item name="elevation">6dp</item>
    </style>

    <!-- NavigationBar样式 -->
    <style name="Widget.App.NavigationBar" parent="Widget.Material3.NavigationBarView">
        <item name="backgroundColor">@color/surface_light</item>
        <item name="itemActiveIndicatorColor">@color/primary_100</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
    </style>

    <!-- ============================================
         文本样式
         ============================================ -->

    <style name="TextAppearance.App.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/on_surface_light</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.App.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/on_surface_light</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.App.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/google_sans_medium</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/on_surface_light</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_light</item>
    </style>

    <style name="TextAppearance.App.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

</resources>