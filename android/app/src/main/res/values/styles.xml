<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础样式 -->
    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_light</item>
        <item name="colorOnPrimary">@color/bg_card</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/nav_bg</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>

    <!-- 卡片样式 -->
    <style name="CardStyle">
        <item name="android:background">@color/bg_card</item>
        <item name="android:elevation">4dp</item>
        <item name="android:radius">24dp</item>
    </style>

    <!-- 文字样式 -->
    <style name="TextTitle">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="TextSubtitle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextBody">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextCaption">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- 按钮样式 -->
    <style name="ButtonPrimary">
        <item name="android:background">@color/brand_primary</item>
        <item name="android:textColor">@color/bg_card</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:radius">12dp</item>
    </style>

    <style name="ButtonSecondary">
        <item name="android:background">@color/brand_light</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:radius">999dp</item>
    </style>

    <!-- 状态标签样式 -->
    <style name="StatusTag">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:radius">999dp</item>
    </style>
</resources>