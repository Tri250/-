#!/bin/bash
# 离线构建脚本
# 使用方法: ./gradlew-offline assembleRelease

echo "=========================================="
echo "离线构建模式"
echo "=========================================="

# 检查依赖是否已缓存
if [ ! -d "$HOME/.gradle/caches" ]; then
    echo "警告: Gradle缓存目录不存在，离线构建可能失败"
    echo "建议先执行一次在线构建以缓存所有依赖"
    exit 1
fi

# 执行离线构建
./gradlew "$@" --offline --build-cache

echo "=========================================="
echo "离线构建完成"
echo "=========================================="
